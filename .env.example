# ─── Required ────────────────────────────────────────────────────────────────
# MySQL/MariaDB connection string (e.g. from PlanetScale, Railway, or local Docker)
DATABASE_URL="mysql://user:password@host:3306/cro_ideas_board"

# Shared secret for authenticating pipeline/research API calls (REQUIRED)
# Used by POST /api/pipeline/run, POST /api/research/generate, POST /api/research/mockup
# Set a long, random string — treat it like a password
RESEARCH_SECRET="your-secret-here"

# ─── LLM Provider (at least one required for idea generation) ────────────────
# Anthropic Claude (preferred — used first if available)
ANTHROPIC_API_KEY="sk-ant-..."

# OpenAI GPT-4o (fallback if Anthropic key is not set)
OPENAI_API_KEY="sk-..."

# ─── Image Generation (required for mockup generation) ───────────────────────
# MiniMax API key for image generation
# Get from https://platform.minimaxi.com
MINIMAX_API_KEY="your-minimax-key"

# ─── Blob Storage (required for mockup persistence) ──────────────────────────
# Vercel Blob read-write token for storing generated mockup images
# Get from https://vercel.com/dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# ─── Optional ────────────────────────────────────────────────────────────────
# Base URL for API calls (defaults to http://localhost:3000 in dev)
# API_BASE="https://your-domain.vercel.app"
