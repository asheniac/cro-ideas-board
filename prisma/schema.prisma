generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum CROIdeaStatus {
  pending
  liked
  disliked
}

model CROIdea {
  id              Int            @id @default(autoincrement())
  title           String
  description     String         @db.Text
  reason          String         @db.Text
  purpose         String         @db.Text
  categoryId      Int
  category        Category       @relation(fields: [categoryId], references: [id])
  status          CROIdeaStatus  @default(pending)
  previousStatus  CROIdeaStatus?
  batchId         String?
  mockupUrl       String?
  mockupPrompt    String?        @db.Text
  sourceUrl       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status])
  @@index([categoryId])
  @@index([createdAt])
}

model Category {
  id      Int       @id @default(autoincrement())
  name    String    @unique
  slug    String    @unique
  ideas   CROIdea[]

  @@index([slug])
}
